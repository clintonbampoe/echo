    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend.Api.Core",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: Backend.Api.Core",
            "program": "${workspaceFolder}/src/Backend.Api.Core/bin/Debug/net10.0/Backend.Api.Core.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Backend.Api.Core",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }

    ]
}
